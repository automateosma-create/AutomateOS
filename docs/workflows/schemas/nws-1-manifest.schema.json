{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/automateosma-create/AutomateOS/blob/main/docs/workflows/schemas/nws-1-manifest.schema.json",
  "title": "AutomateOS n8n Workflow Manifest",
  "description": "Machine-readable manifest for an AutomateOS NWS-1 workflow pack.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec",
    "workflow_id",
    "n8n_name",
    "version",
    "status",
    "risk",
    "owner",
    "last_verified",
    "trigger",
    "artifacts",
    "systems",
    "source_of_truth",
    "nodes",
    "branches",
    "side_effects",
    "health_check"
  ],
  "properties": {
    "spec": {"const": "NWS-1"},
    "workflow_id": {
      "type": "string",
      "pattern": "^wf_[a-z0-9_]+$"
    },
    "n8n_name": {"type": "string", "minLength": 1},
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "enum": ["production", "planned", "exploratory", "deprecated", "retired"]
    },
    "risk": {"enum": ["low", "medium", "high", "critical"]},
    "owner": {"type": "string", "minLength": 1},
    "last_verified": {"type": "string", "format": "date"},
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "enum": ["webhook", "schedule", "manual", "subworkflow", "email", "event", "other"]
        },
        "path": {"type": "string"},
        "schedule": {"type": "string"},
        "source": {"type": "string"}
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["spec", "manifest", "workflow_export", "code", "fixtures"],
      "properties": {
        "spec": {"$ref": "#/$defs/completeness"},
        "manifest": {"$ref": "#/$defs/completeness"},
        "workflow_export": {"$ref": "#/$defs/completeness"},
        "code": {"$ref": "#/$defs/completeness"},
        "fixtures": {"$ref": "#/$defs/completeness"}
      }
    },
    "systems": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reads", "writes"],
      "properties": {
        "reads": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        },
        "writes": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        }
      }
    },
    "source_of_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary"],
      "properties": {
        "primary": {"type": "string", "minLength": 1},
        "secondary": {
          "type": "array",
          "items": {"type": "string"},
          "uniqueItems": true
        }
      }
    },
    "credentials": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["alias", "system"],
        "properties": {
          "alias": {"type": "string", "minLength": 1},
          "system": {"type": "string", "minLength": 1},
          "purpose": {"type": "string"}
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "type"],
        "properties": {
          "id": {"type": "string", "pattern": "^N[0-9]{2,}$"},
          "name": {"type": "string", "minLength": 1},
          "type": {"type": "string", "minLength": 1},
          "code_file": {"type": "string"},
          "reads": {"type": "array", "items": {"type": "string"}},
          "writes": {"type": "array", "items": {"type": "string"}},
          "next": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "branches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "condition", "outcome"],
        "properties": {
          "id": {"type": "string", "pattern": "^B[0-9]{2,}$"},
          "condition": {"type": "string", "minLength": 1},
          "outcome": {"type": "string", "minLength": 1},
          "nodes": {"type": "array", "items": {"type": "string"}},
          "mutation": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "side_effects": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "idempotency": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "key": {"type": "string"},
        "rule": {"type": "string"}
      }
    },
    "health_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {"enum": ["implemented", "partial", "missing", "not_applicable"]},
        "reference": {"type": "string"},
        "notes": {"type": "string"}
      }
    },
    "known_gaps": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "$defs": {
    "completeness": {
      "enum": ["complete", "partial", "missing", "not_applicable"]
    }
  }
}
